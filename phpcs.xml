<?xml version="1.0"?>
<ruleset name="MoodlePluginCustomChecks">
    <description>Config customzed to the Codechecker.</description>
    
    <!-- Use the pattern by Moodle -->
    <rule ref="moodle"/>

    <!-- Avoid folder don't need to check -->
    <exclude-pattern>*/thirdparty/*</exclude-pattern>
    <exclude-pattern>*/yui/build/*</exclude-pattern>
    <exclude-pattern>*/node_modules/*</exclude-pattern>
    <exclude-pattern>*/tests/*</exclude-pattern>

    <!-- Config extra -->
    <arg name="colors"/>
    <!-- Show the progress -->
    <arg value="p"/> 
</ruleset>